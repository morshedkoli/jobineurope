# ─── Core ──────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
# Shared secret so Vercel Cron can trigger job ingestion. Generate any random string.
CRON_SECRET=

# ─── MongoDB Atlas ───────────────────────────────────────────────────────────
# Atlas connection string. Create a free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=jobineurope

# ─── Auth.js (NextAuth v5) ───────────────────────────────────────────────────
# Generate: npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# GitHub OAuth app: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth: https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── AI providers (provider-agnostic routing) ───────────────────────────────
# Pick which provider serves chat vs. embeddings. All providers below need
# ONLY an API key, except Cloudflare (needs account ID too).
#   chat:  openrouter nim groq together fireworks deepinfra mistral openai
#          gemini deepseek xai cerebras perplexity cloudflare
#   embed: nim together fireworks deepinfra mistral openai gemini voyage cloudflare
AI_CHAT_PROVIDER=openrouter
AI_EMBED_PROVIDER=cloudflare

# Atlas Vector Search index name (auto-created best-effort; cosine fallback otherwise).
VECTOR_INDEX_NAME=job_vectors
# How many shortlisted jobs to LLM-score per rescore (controls cost).
MATCH_SCORE_LIMIT=20

# Dimensions MUST match your embed model AND your Atlas vector index.
# bge-m3 / nv-embedqa-e5-v5 / mistral-embed / voyage-3 = 1024
# text-embedding-004 (gemini) / bge-base / nomic = 768 ; openai 3-small = 1536
EMBED_DIMENSIONS=1024

# Per-provider model overrides are optional: {ID}_CHAT_MODEL / {ID}_EMBED_MODEL
# (e.g. GROQ_CHAT_MODEL, OPENAI_EMBED_MODEL). Sensible defaults ship in code.

# --- Key-only providers (fill the one[s] you use) ---
# OpenRouter — https://openrouter.ai/keys  (chat; routes to most models)
OPENROUTER_API_KEY=
# NVIDIA NIM — https://build.nvidia.com  (chat + embeddings, generous free tier)
NVIDIA_NIM_API_KEY=
# Groq — https://console.groq.com/keys  (chat, very fast, free tier)
GROQ_API_KEY=
# Together AI — https://api.together.ai/settings/api-keys  (chat + embeddings)
TOGETHER_API_KEY=
# Fireworks AI — https://fireworks.ai/account/api-keys  (chat + embeddings)
FIREWORKS_API_KEY=
# DeepInfra — https://deepinfra.com/dash/api_keys  (chat + embeddings)
DEEPINFRA_API_KEY=
# Mistral AI — https://console.mistral.ai/api-keys  (chat + embeddings)
MISTRAL_API_KEY=
# OpenAI — https://platform.openai.com/api-keys  (chat + embeddings)
OPENAI_API_KEY=
# Google Gemini — https://aistudio.google.com/apikey  (chat + embeddings)
GEMINI_API_KEY=
# DeepSeek — https://platform.deepseek.com/api_keys  (chat)
DEEPSEEK_API_KEY=
# xAI Grok — https://console.x.ai  (chat)
XAI_API_KEY=
# Cerebras — https://cloud.cerebras.ai  (chat, very fast, free tier)
CEREBRAS_API_KEY=
# Perplexity — https://www.perplexity.ai/settings/api  (chat, web-grounded)
PERPLEXITY_API_KEY=
# Voyage AI — https://dashboard.voyageai.com  (embeddings only, top quality)
VOYAGE_API_KEY=

# --- Cloudflare Workers AI (needs account ID + token, not key-only) ---
# https://dash.cloudflare.com  →  AI  →  Workers AI
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_CHAT_MODEL=@cf/meta/llama-3.1-8b-instruct
CLOUDFLARE_EMBED_MODEL=@cf/baai/bge-m3

# ─── Job sources (Phase 2) ───────────────────────────────────────────────────
# Adzuna — https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Arbeitnow needs no key (public API).
